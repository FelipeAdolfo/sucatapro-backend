  "description": "Backend API para SucataPro - Plataforma de Gestão de Compras de Sucata",
  "main": "dist/server.js",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
